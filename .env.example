# Local runtime configuration example.
# Copy to .env for local development. Never commit real credentials.

# Upstream Google Lens request settings.
GOOGLE_BASE_URL=https://lens.google.com/uploadbyurl
REQUEST_TIMEOUT_SECONDS=30.0
MAX_CONCURRENCY=4
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36

# Generic proxy option. Takes precedence over MrScraper-specific settings.
# PROXY_URL=http://username:password@proxy.example.com:8080

# MrScraper Residential Proxy option.
# MRSCRAPER_PROXY_USERNAME=user123
# MRSCRAPER_PROXY_PASSWORD=pass456
# MRSCRAPER_PROXY_COUNTRY=us
# MRSCRAPER_PROXY_MOBILE=true
# MRSCRAPER_PROXY_SESSION_ID=lens1
# MRSCRAPER_PROXY_SESSION_MINUTES=20
